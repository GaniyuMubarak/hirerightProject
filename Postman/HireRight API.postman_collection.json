      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Parse response\r",
                  "const response = pm.response.json();\r",
                  "\r",
                  "// Save token to environment if registration successful\r",
                  "if (response.token) {\r",
                  "    pm.environment.set(\"token\", response.token);\r",
                  "    console.log(\"✅ Token saved:\", response.token);\r",
                  "    \r",
                  "    // Also save user info for reference\r",
                  "    if (response.user) {\r",
                  "        pm.environment.set(\"user_id\", response.user.id);\r",
                  "        pm.environment.set(\"user_email\", response.user.email);\r",
                  "        pm.environment.set(\"user_role\", response.user.app_role);\r",
                  "    }\r",
                  "} else {\r",
                  "    console.log(\"❌ No token in response\");\r",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Ridone\",\n  \"last_name\": \"Lahi\",\n  \"email\": \"abimbolaalimat12@gmail.com\",\n  \"password\": \"Test@123\",\n  \"password_confirmation\": \"Test@123\",\n  \"app_role\": \"candidate\"\n}",
